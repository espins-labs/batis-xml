<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.WidgetMapper">
  <select id="searchWidgetsTrim" resultType="com.example.demo.model.Widget">
    SELECT widget_id, widget_name FROM demo_widget
    <trim prefix="WHERE" prefixOverrides="AND |OR ">
      <if test="name != null">AND widget_name = #{name}</if>
      <if test="status != null">AND status = #{status}</if>
    </trim>
  </select>
</mapper>
