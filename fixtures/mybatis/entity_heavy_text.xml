<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.WidgetMapper">
  <select id="selectWidgetsLegacyEntities" resultType="com.example.demo.model.Widget">
    SELECT widget_id, widget_name FROM demo_widget
    WHERE widget_name &lt;&gt; '' AND category_flag &amp; 1 = 1
    <!-- legacy export kept a raw &nbsp; entity in the description comparison -->
    AND description != '&nbsp;test&#64;example'
  </select>
</mapper>
