<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.WidgetMapper">
  <resultMap id="widgetWithOwnerAndTagsMap" type="com.example.demo.model.Widget">
    <id column="widget_id" property="id"/>
    <result column="widget_name" property="name"/>
    <association property="owner" javaType="com.example.demo.model.Owner">
      <id column="owner_id" property="id"/>
      <result column="owner_name" property="name"/>
    </association>
    <collection property="tags" ofType="com.example.demo.model.Tag">
      <id column="tag_id" property="id"/>
      <result column="tag_label" property="label"/>
    </collection>
  </resultMap>
</mapper>
