<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.WidgetMapper">
  <select id="searchWidgetsByName" resultType="com.example.demo.model.Widget">
    SELECT widget_id, widget_name FROM demo_widget
    <where>
      <if test="name != null">AND widget_name = #{name}</if>
    </where>
  </select>
</mapper>
