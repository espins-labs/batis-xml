<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.WidgetMapper">
  <sql id="auditColumns">created_at, updated_at</sql>
  <sql id="baseColumns">widget_id, widget_name, <include refid="auditColumns"/></sql>
  <select id="selectWidgetById" resultType="com.example.demo.model.Widget">
    SELECT <include refid="baseColumns"/>
    FROM demo_widget
    WHERE widget_id = #{id}
  </select>
</mapper>
