<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.WidgetMapper">
  <sql id="orderByColumn">ORDER BY widget_id</sql>
  <select id="selectWidgetsSorted" resultType="com.example.demo.model.Widget">
    SELECT widget_id, widget_name FROM demo_widget
    <include refid="orderByColumn">
      <property name="column" value="widget_name"/>
    </include>
  </select>
</mapper>
