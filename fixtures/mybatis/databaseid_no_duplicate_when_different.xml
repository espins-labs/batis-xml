<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.WidgetMapper">
  <select id="selectWidgetPage" databaseId="oracle" resultType="com.example.demo.model.Widget">
    SELECT widget_id, widget_name FROM demo_widget WHERE ROWNUM &lt;= 10
  </select>
  <select id="selectWidgetPage" databaseId="mysql" resultType="com.example.demo.model.Widget">
    SELECT widget_id, widget_name FROM demo_widget LIMIT 10
  </select>
</mapper>
