<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//ibatis.apache.org//DTD SQL Map 2.0//EN"
  "http://ibatis.apache.org/dtd/sql-map-2.dtd">
<sqlMap>
  <resultMap id="widgetResult" class="widget">
    <result column="widget_id" property="id"/>
    <result column="widget_name" property="name"/>
  </resultMap>
  <select id="widgetDAO.selectWidget" parameterClass="map" resultMap="widgetResult">
    SELECT widget_id, widget_name FROM demo_widget WHERE widget_id = #id#
  </select>
</sqlMap>
