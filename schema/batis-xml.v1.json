{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ParseResult",
  "type": "object",
  "required": [
    "diagnostics",
    "dialect"
  ],
  "properties": {
    "diagnostics": {
      "description": "Parsing never fails — every anomaly accumulates here.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/Diagnostic"
      }
    },
    "dialect": {
      "$ref": "#/definitions/Dialect"
    },
    "mapper": {
      "description": "`None` when the root element is not a mapper/sqlMap (reason is reported as a diagnostic).",
      "anyOf": [
        {
          "$ref": "#/definitions/Mapper"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "ByteSpan": {
      "description": "Half-open range `[start, end)` in **original bytes** — never in the decoded string.\n\nCaveat: this holds exactly for UTF-8 input, which decoding leaves byte-for-byte unchanged. For documents that were re-encoded from EUC-KR/CP949 (see `encoding.rs`), decoding to UTF-8 changes byte *widths* per character, so spans on such documents are offsets into the re-encoded UTF-8 string, not the original raw bytes. Consumers reading spans back against a source file must decode that source the same way this crate did before slicing.",
      "type": "object",
      "required": [
        "end",
        "start"
      ],
      "properties": {
        "end": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "start": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    },
    "ClassRef": {
      "description": "Alias resolution is the consumer's job — only the raw text is kept.",
      "type": "object",
      "required": [
        "raw"
      ],
      "properties": {
        "raw": {
          "type": "string"
        }
      }
    },
    "ColumnMapping": {
      "type": "object",
      "properties": {
        "column": {
          "type": [
            "string",
            "null"
          ]
        },
        "property": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "DiagCode": {
      "description": "Additions only; removal/renaming is breaking. `#[non_exhaustive]` because new codes may appear within v1 itself (see `schema/README.md`) -- an exhaustive `match` outside this crate must add a wildcard arm, which is exactly the forward-compat behavior consumers need (an unrecognized code is not an error). `Other` covers the equivalent case for *deserialization* (this build reading JSON produced by a newer version).",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "encoding_undetectable",
            "encoding_mismatch",
            "unclosed_tag",
            "duplicate_statement_id",
            "missing_statement_id",
            "dangling_refid",
            "branch_limit_exceeded",
            "unknown_element",
            "oversize_input"
          ]
        },
        {
          "description": "Recovery rule 3: first value wins, duplicate is reported here.",
          "type": "string",
          "enum": [
            "duplicate_attribute"
          ]
        },
        {
          "description": "An entity reference could not be resolved (e.g. `&nbsp;`, common in legacy mappers). The raw text is kept as-is for that segment (MM-08).",
          "type": "string",
          "enum": [
            "invalid_entity"
          ]
        },
        {
          "description": "A `#{`/`${`/legacy `#..#`/`$..$` placeholder never found its closing delimiter within the segment. The raw text is kept as-is (MM-07).",
          "type": "string",
          "enum": [
            "unterminated_placeholder"
          ]
        },
        {
          "description": "Recursion depth exceeded 256 nesting levels (dynamic-tag flattening or resultMap association/discriminator nesting) -- the remaining subtree is treated as opaque (no text/mapping contribution) rather than risk a stack overflow. Cold code review B2/B3, 2026-07-05.",
          "type": "string",
          "enum": [
            "nesting_limit_exceeded"
          ]
        },
        {
          "description": "Forward-compat deserialization fallback: any code string this build doesn't recognize (e.g. JSON produced by a newer batis-xml version) lands here instead of failing to deserialize. Never produced by this crate's own parser -- hidden from docs since it's a deserialization mechanism, not a diagnostic you'd match on intentionally. Cold code-review contract audit, 2026-07-05.",
          "type": "string",
          "enum": [
            "other"
          ]
        }
      ]
    },
    "Diagnostic": {
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "$ref": "#/definitions/DiagCode"
        },
        "message": {
          "type": "string"
        },
        "span": {
          "anyOf": [
            {
              "$ref": "#/definitions/ByteSpan"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "Dialect": {
      "description": "Closed set: an exhaustive `match` is a consumer feature (there's no forward-compat concern the way there is for `DiagCode`/`SqlText`, since `Unknown` already covers \"neither of the two known dialects\"). Adding a third dialect would be a v2.",
      "type": "string",
      "enum": [
        "mybatis",
        "ibatis",
        "unknown"
      ]
    },
    "IncludeRef": {
      "type": "object",
      "required": [
        "raw",
        "target"
      ],
      "properties": {
        "raw": {
          "type": "string"
        },
        "target": {
          "$ref": "#/definitions/IncludeTarget"
        }
      }
    },
    "IncludeTarget": {
      "description": "Closed set: an exhaustive `match` is a consumer feature. `Dynamic` already covers \"can't be resolved statically\" -- there's no third kind of refid target. Adding a variant here would be a v2.",
      "oneOf": [
        {
          "type": "object",
          "required": [
            "local"
          ],
          "properties": {
            "local": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "qualified"
          ],
          "properties": {
            "qualified": {
              "type": "object",
              "required": [
                "id",
                "ns"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "ns": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "description": "`${}`-driven refid — marked unresolvable.",
          "type": "string",
          "enum": [
            "dynamic"
          ]
        }
      ]
    },
    "Mapper": {
      "type": "object",
      "required": [
        "fragments",
        "result_maps",
        "statements"
      ],
      "properties": {
        "fragments": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/SqlFragment"
          }
        },
        "namespace": {
          "description": "Usually `None` for iBatis sqlMaps (observed in the wild: the prefix lives inside the statement id itself, e.g. `WidgetDAO.getWidget`).",
          "anyOf": [
            {
              "$ref": "#/definitions/Spanned_for_String"
            },
            {
              "type": "null"
            }
          ]
        },
        "result_maps": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ResultMap"
          }
        },
        "statements": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Statement"
          }
        }
      }
    },
    "ResultMap": {
      "type": "object",
      "required": [
        "id",
        "mappings"
      ],
      "properties": {
        "extends": {
          "anyOf": [
            {
              "$ref": "#/definitions/Spanned_for_String"
            },
            {
              "type": "null"
            }
          ]
        },
        "id": {
          "$ref": "#/definitions/Spanned_for_String"
        },
        "mappings": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ColumnMapping"
          }
        },
        "span": {
          "description": "Full original extent: opening-tag start → subtree end.",
          "default": {
            "end": 0,
            "start": 0
          },
          "allOf": [
            {
              "$ref": "#/definitions/ByteSpan"
            }
          ]
        },
        "type_ref": {
          "anyOf": [
            {
              "$ref": "#/definitions/Spanned_for_ClassRef"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "Spanned_for_ClassRef": {
      "type": "object",
      "required": [
        "span",
        "value"
      ],
      "properties": {
        "span": {
          "$ref": "#/definitions/ByteSpan"
        },
        "value": {
          "$ref": "#/definitions/ClassRef"
        }
      }
    },
    "Spanned_for_IncludeRef": {
      "type": "object",
      "required": [
        "span",
        "value"
      ],
      "properties": {
        "span": {
          "$ref": "#/definitions/ByteSpan"
        },
        "value": {
          "$ref": "#/definitions/IncludeRef"
        }
      }
    },
    "Spanned_for_String": {
      "type": "object",
      "required": [
        "span",
        "value"
      ],
      "properties": {
        "span": {
          "$ref": "#/definitions/ByteSpan"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "SqlFragment": {
      "type": "object",
      "required": [
        "id",
        "includes",
        "sql"
      ],
      "properties": {
        "id": {
          "$ref": "#/definitions/Spanned_for_String"
        },
        "includes": {
          "description": "Nested includes inside the fragment (MM-04).",
          "type": "array",
          "items": {
            "$ref": "#/definitions/Spanned_for_IncludeRef"
          }
        },
        "span": {
          "description": "Full original extent: opening-tag start → subtree end.",
          "default": {
            "end": 0,
            "start": 0
          },
          "allOf": [
            {
              "$ref": "#/definitions/ByteSpan"
            }
          ]
        },
        "sql": {
          "$ref": "#/definitions/SqlText"
        }
      }
    },
    "SqlString": {
      "description": "Flattened SQL text plus a mapping back to the source.",
      "type": "object",
      "required": [
        "span_map",
        "text"
      ],
      "properties": {
        "span_map": {
          "description": "(synthetic-text offset, original byte offset) segment-start pairs — strictly increasing.",
          "type": "array",
          "items": {
            "type": "array",
            "items": [
              {
                "type": "integer",
                "format": "uint32",
                "minimum": 0.0
              },
              {
                "type": "integer",
                "format": "uint32",
                "minimum": 0.0
              }
            ],
            "maxItems": 2,
            "minItems": 2
          }
        },
        "text": {
          "description": "Placeholders already normalized: `#{..}` → `?`, `${..}` → `__BATIS_DYN__`.",
          "type": "string"
        }
      }
    },
    "SqlText": {
      "description": "Result of dynamic-tag flattening (MM-06). Branch combination cap N=32 — total candidates per statement, computed as the cartesian product of tag branches.\n\n`#[non_exhaustive]`: a third fallback representation is plausible future work, and consumers matching exhaustively today must not break at compile time if one's added.",
      "oneOf": [
        {
          "type": "object",
          "required": [
            "variants"
          ],
          "properties": {
            "variants": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/SqlVariant"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Over-cap fallback (accompanied by a `BranchLimitExceeded` diagnostic).",
          "type": "object",
          "required": [
            "union"
          ],
          "properties": {
            "union": {
              "type": "object",
              "required": [
                "branch_count",
                "text"
              ],
              "properties": {
                "branch_count": {
                  "description": "A **lower bound**, not necessarily the exact branch count: flattening bails out of cartesian expansion as soon as it's certain the total exceeds the cap, without finishing the (possibly much larger) exact count. Treat this as \"at least this many, over the cap\" rather than a precise total.",
                  "type": "integer",
                  "format": "uint32",
                  "minimum": 0.0
                },
                "text": {
                  "$ref": "#/definitions/SqlString"
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "SqlVariant": {
      "type": "object",
      "required": [
        "conditions",
        "text"
      ],
      "properties": {
        "conditions": {
          "description": "The `test` expressions (verbatim) that activate this variant.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "text": {
          "$ref": "#/definitions/SqlString"
        }
      }
    },
    "Statement": {
      "type": "object",
      "required": [
        "includes",
        "kind",
        "property_paths",
        "sql"
      ],
      "properties": {
        "database_id": {
          "description": "MyBatis per-vendor branching (`databaseId=\"oracle\"` etc.) — `None` when the statement doesn't declare one. Distinguishes otherwise duplicate ids (MM-03).",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/Spanned_for_String"
            },
            {
              "type": "null"
            }
          ]
        },
        "id": {
          "description": "`None` when missing, plus a `MissingStatementId` diagnostic. Synthesized ids are never invented.",
          "anyOf": [
            {
              "$ref": "#/definitions/Spanned_for_String"
            },
            {
              "type": "null"
            }
          ]
        },
        "includes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Spanned_for_IncludeRef"
          }
        },
        "kind": {
          "$ref": "#/definitions/StatementKind"
        },
        "param_class": {
          "anyOf": [
            {
              "$ref": "#/definitions/Spanned_for_ClassRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "property_paths": {
          "description": "Expression paths collected from `#{a.b}` / `${c}` (MM-07).",
          "type": "array",
          "items": {
            "$ref": "#/definitions/Spanned_for_String"
          }
        },
        "result_class": {
          "anyOf": [
            {
              "$ref": "#/definitions/Spanned_for_ClassRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "result_map_ref": {
          "anyOf": [
            {
              "$ref": "#/definitions/Spanned_for_String"
            },
            {
              "type": "null"
            }
          ]
        },
        "span": {
          "description": "Full original extent of the statement: opening-tag start → subtree end (i.e. past its closing tag, or its own end for a self-closed element).",
          "default": {
            "end": 0,
            "start": 0
          },
          "allOf": [
            {
              "$ref": "#/definitions/ByteSpan"
            }
          ]
        },
        "sql": {
          "$ref": "#/definitions/SqlText"
        }
      }
    },
    "StatementKind": {
      "description": "Closed set: an exhaustive `match` is a consumer feature. `Generic` already covers \"some other statement-like tag with no CRUD-verb equivalent\" -- a new MyBatis/iBatis statement-like tag would be recognized by adding to `Generic`'s callers, not by growing this enum. Adding a variant here would be a v2.",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "select",
            "insert",
            "update",
            "delete",
            "procedure"
          ]
        },
        {
          "description": "iBatis `<statement>` — a generic statement tag with no MyBatis CRUD-verb equivalent.",
          "type": "string",
          "enum": [
            "generic"
          ]
        }
      ]
    }
  }
}
